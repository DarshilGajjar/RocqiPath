# --- Byte-compiled / cache ---------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Distribution / packaging -------------------------------------------------
build/
dist/
*.egg-info/
.eggs/
wheelhouse/

# --- Virtual environments -------------------------------------------------
.venv/
venv/
env/
ENV/

# --- Testing / coverage -----------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# --- IDE / editor -------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# --- OS cruft -------------------------------------------------------
.DS_Store
Thumbs.db

